APP_URL="MY_APP_URL"

# --- Resend (envio de e-mail do formulário de contato) ---
# Crie sua chave em https://resend.com/api-keys
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# E-mail que vai RECEBER os leads do formulário.
CONTACT_TO_EMAIL="seu-email@seudominio.com"

# Remetente. Em produção precisa ser de um domínio verificado no Resend.
# Para testes rápidos, use: "BWeber <onboarding@resend.dev>"
CONTACT_FROM_EMAIL="BWeber <onboarding@resend.dev>"

# Porta do servidor Express (opcional; padrão 3001).
PORT=3001
